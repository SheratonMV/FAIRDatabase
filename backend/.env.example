# =============================================================================
# FAIRDatabase - Environment Configuration
# =============================================================================
#
# Quick start:
#   1. Copy this file to .env:       cp .env.example .env
#   2. Set the required passwords below
#   3. Run bootstrap:                bash ../scripts/bootstrap.sh
#   4. Start everything:             docker compose up -d
#
# The bootstrap script reads your passwords from .env and auto-generates
# all derived secrets (JWT tokens, API keys, internal configs).

# =============================================================================
# REQUIRED: Set these before running bootstrap
# =============================================================================

# Database password (used by PostgreSQL and all Supabase services)
POSTGRES_PASSWORD=change-me

# Supabase Studio dashboard login password (username: supabase)
DASHBOARD_PASSWORD=change-me

# Flask application secret key (used for session signing)
SECRET_KEY=change-me

# =============================================================================
# OPTIONAL: Defaults work for local development
# =============================================================================

# Your app URL (where users access the Flask app)
SITE_URL=http://localhost:5000

# SMTP settings (leave empty to disable email sending)
SMTP_HOST=
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=FAIRDatabase

# Set to true to disable new user registration
DISABLE_SIGNUP=false

# Set to false in production (requires email verification)
ENABLE_EMAIL_AUTOCONFIRM=true

# Federated learning API (external service URL)
FED_API_BASE=http://host.docker.internal:7070
