# =============================================================================
# FAIRDatabase Docker Environment Variables
# =============================================================================
#
# This file documents ALL environment variables needed for the Docker deployment.
# Run `bash scripts/bootstrap.sh` to auto-generate a working .env file,
# or copy this file to .env and fill in the values manually.
#
# Variables marked [AUTO] are generated automatically by bootstrap.sh.
# Variables marked [MANUAL] should be set by the user.

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me                       # [AUTO] Database password
POSTGRES_HOST=db                                  # Container service name (don't change)
POSTGRES_PORT=5432                                # Internal container port (don't change)
POSTGRES_DB=postgres                              # Database name

# --- Supabase JWT ---
JWT_SECRET=your-jwt-secret-at-least-32-chars      # [AUTO] Must be >= 32 chars
JWT_EXPIRY=3600                                   # Token expiry in seconds
ANON_KEY=generated-anon-jwt                       # [AUTO] Generated from JWT_SECRET
SERVICE_ROLE_KEY=generated-service-role-jwt        # [AUTO] Generated from JWT_SECRET

# --- Supabase API ---
SITE_URL=http://localhost:5000                    # Your app URL
API_EXTERNAL_URL=http://localhost:8000            # Supabase API URL
SUPABASE_PUBLIC_URL=http://localhost:8000          # Public Supabase URL
ADDITIONAL_REDIRECT_URLS=                         # Comma-separated redirect URLs
DISABLE_SIGNUP=false                              # Set true to disable new registrations

# --- Supabase Studio ---
STUDIO_DEFAULT_ORGANIZATION=FAIRDatabase
STUDIO_DEFAULT_PROJECT=FAIRDatabase
DASHBOARD_USERNAME=supabase                       # [MANUAL] Studio login username
DASHBOARD_PASSWORD=change-me                      # [AUTO] Studio login password
STUDIO_PORT=3000

# --- Email Auth ---
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true                     # Set false in production
ENABLE_ANONYMOUS_USERS=false

# --- Phone Auth (disabled) ---
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# --- SMTP ---
SMTP_ADMIN_EMAIL=admin@example.com                # [MANUAL] for production
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=FAIRDatabase

# --- Mailer URLs ---
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# --- Kong ---
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# --- PostgREST ---
PGRST_DB_SCHEMAS=public,_fd,storage,graphql_public

# --- Realtime ---
SECRET_KEY_BASE=your-secret-key-base              # [AUTO]

# --- Edge Functions ---
FUNCTIONS_VERIFY_JWT=true

# --- Supavisor (Connection Pooler) ---
POOLER_TENANT_ID=fairdatabase
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_PROXY_PORT_TRANSACTION=6543
VAULT_ENC_KEY=your-vault-enc-key                  # [AUTO]

# --- Docker / Podman ---
DOCKER_SOCKET_LOCATION=/var/run/docker.sock       # Podman: /run/user/$(id -u)/podman/podman.sock

# --- Image Proxy ---
IMGPROXY_ENABLE_WEBP_DETECTION=true

# --- Logflare ---
LOGFLARE_API_KEY=placeholder-key

# --- Flask Application ---
ENV=development
SECRET_KEY=your-flask-secret                      # [AUTO]
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=csv

# Flask-specific Supabase vars (different naming from Supabase compose vars)
SUPABASE_URL=http://kong:8000
SUPABASE_KEY=same-as-ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=same-as-SERVICE_ROLE_KEY
POSTGRES_USER=postgres
POSTGRES_SECRET=same-as-POSTGRES_PASSWORD
POSTGRES_DB_NAME=postgres

# --- Federated Learning ---
FED_API_BASE=http://host.docker.internal:7070

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000
